# QueryForge Configuration

# Optional: LLM fallback for complex queries (not required for rule-based mode)
# OPENAI_API_KEY=sk-...

# SQL dialect: sqlite, postgresql, mysql
QUERYFORGE_DIALECT=sqlite

# Logging level: DEBUG, INFO, WARNING, ERROR
QUERYFORGE_LOG_LEVEL=INFO

# Enable SQL validation (recommended)
QUERYFORGE_VALIDATE=true
